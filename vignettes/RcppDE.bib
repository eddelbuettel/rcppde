  volume =       {40},
  url =          {https://www.jstatsoft.org/index.php/jss/article/view/v040i06},
  doi =          {10.18637/jss.v040.i06},
  abstract =     {This article describes the R package
                  &amp;lt;b&amp;gt;DEoptim&amp;lt;/b&amp;gt;, which
                  implements the differential evolution algorithm for
                  global optimization of a real-valued function of a
                  real-valued parameter vector. The implementation of
                  differential evolution in
                  &amp;lt;b&amp;gt;DEoptim&amp;lt;/b&amp;gt;
                  interfaces with C code for efficiency. The utility
                  of the package is illustrated by case studies in
                  fitting a Parratt model for X-ray reflectometry data
                  and a Markov-switching generalized autoregressive
                  conditional heteroskedasticity model for the returns
                  of the Swiss Market Index.},
